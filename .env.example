# ============================================================
# 生产环境配置模板 (.env.example)
# 复制为 .env 并填入真实值
# ============================================================

# --- 应用认证 ---
APP_KEY=default_app_key
APP_SECRET=default_app_secret

# --- Gitea ---
GITEA_BASE_URL=http://172.22.4.242:3000
GITEA_TOKEN=1aa29d2c2de77b0618293ee63aa2329f4184f266
GITEA_FILE_OB=/api/v1/repos/{owner}/{repo}/contents/{filepath}

# --- PostgreSQL ---
POSTGRES_DSN=postgresql+asyncpg://retrieval:maanShan202605@172.22.4.242:5432/data_quality_eva
REDIS_URL=redis://172.22.4.242:6379/2

# --- 模型配置 ---
# 所有模型通过 ModelScope 下载，model_name 使用 HuggingFace 格式
MODEL_NAME=google/gemma-4-e4b
MODEL_CACHE_DIR=./models
DEVICE=cpu
GPU_CONCURRENCY=2

# --- 模型服务地址 ---
MODEL_SERVER_URL=http://127.0.0.1:8100

# --- 性能 ---
CELERY_WORKER_CONCURRENCY=4
MAX_TEXT_CHARS=8000

# --- 日志 ---
LOG_LEVEL=INFO

# --- 连接池 ---
DB_POOL_MIN_SIZE=2
DB_POOL_MAX_SIZE=10